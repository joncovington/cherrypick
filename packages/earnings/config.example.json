{
  "enable_live_trading": false,

  "max_concurrent_earnings_positions": 3,

  "earnings_calendar_source": "dolthub",
  "dolthub_host": "127.0.0.1",
  "dolthub_port": 3306,
  "dolthub_user": "root",
  "dolthub_database": "earnings",
  "dolthub_options_database": "options",
  "dolthub_stocks_database": "stocks",

  "winrate_lookback_quarters": 8,

  "finnhub_api_key_env_var": "FINNHUB_API_KEY",

  "entry_window_start": "15:30",
  "entry_window_end": "15:55",
  "close_window_start": "09:45",

  "correlation_block_list": [],

  "reprice_interval_s": 10,
  "reprice_step": 0.05,

  "strategies": {
    "iron_fly": {
      "max_risk_per_trade_pct": 0.02,

      "min_price": 10.00,
      "max_front_expiration_days": 9,
      "require_weekly_options": true,
      "min_combined_open_interest": 2000,
      "max_atm_delta_abs": 0.57,
      "min_expected_move_dollars": 0.90,
      "min_term_structure": -0.004,

      "min_avg_volume": 1500000,
      "near_miss_min_avg_volume": 1000000,

      "min_iv_rv_ratio": 1.25,
      "near_miss_min_iv_rv_ratio": 1.00,

      "min_winrate": 0.50,
      "near_miss_min_winrate": 0.40,

      "wing_width_credit_multiple": 3.0,
      "_wing_width_note": "wing_width_credit_multiple is the fallback if iv_rv_ratio can't be refetched at entry time; otherwise superseded by the bands below, scaled to this candidate's own IV/RV ratio (not market-wide VIX -- an earnings move is idiosyncratic to one stock, so its own IV/RV is a more relevant regime signal here than broad market volatility). Reasoned proposal, not backtested for this strategy.",
      "wing_width_multiple_low": 2.5,
      "wing_width_multiple_mid": 3.0,
      "wing_width_multiple_high": 3.5,
      "wing_width_band_low_max": 1.25,
      "wing_width_band_mid_max": 1.75
    }
  }
}
