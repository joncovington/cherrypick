# Local config (copy config.example.json to config.json and customize)
config.json

# Trade database and WAL files
data/*.db
data/*.db-shm
data/*.db-wal

# Generated strategy selection results
data/strategy_selection_results.json

# Local DoltHub clones (multi-GB, machine-local -- see README's setup steps)
dolt-data/

# Agent logs and EOD reports
logs/*.log
logs/eod-*.md
paper_trading_logs/*.*

# Python bytecode
__pycache__/
*.py[cod]

# Environment files
.env
.env.*

# VS Code workspace (IDE-specific, not project config)
.vscode/
*.code-workspace

# Local Claude Code overrides (machine-specific enablement flags)
.claude/settings.local.json

# MCP server config (machine-local)
.mcp.json

# Claude Flow (machine-local metrics and daemon state)
.claude-flow/

# Auto-installed Claude Code skills and agent plugins (machine-local)
.claude/skills/
.claude/agents/
.claude/commands/
.claude/helpers/
.claude/.proven-config-version
.claude/proven-config.json
skills-lock.json
.swarm/

# Temporary files
cmd_save_close
.tmp/

# Dolt 
config.yaml
.dolt/
