{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python db.py *)",
      "Bash(python notify.py *)",
      "Bash(python -c *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git check-ignore *)",
      "PowerShell(python db.py *)",
      "PowerShell(python notify.py *)",
      "PowerShell(python -c *)",
      "PowerShell(python *.py)"
    ]
  },
  "mcpServers": {
    "tastytrade": {
      "command": "tastytrade-mcp",
      "env": {
        "TASTYTRADE_SANDBOX": "true",
        "ENABLE_LIVE_TRADING": "false",
        "FORCE_DRY_RUN": "false",
        "BUYING_POWER_BUFFER_PCT": "25",
        "ACCOUNT_DEPLOY_LIMIT_PCT": "80"
      }
    },
    "tastytrade-mock": {
      "command": "tastytrade-mcp",
      "args": [
        "--mock",
        "--mock-fixture",
        "tests/mock_fixture.json",
        "--enable-live-trading"
      ],
      "env": {
        "BUYING_POWER_BUFFER_PCT": "25",
        "ACCOUNT_DEPLOY_LIMIT_PCT": "80"
      }
    }
  }
}
