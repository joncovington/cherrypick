{
  "permissions": {
    "allow": [
      "Bash(python *)",
      "Bash(python db.py *)",
      "Bash(python notify.py *)",
      "Bash(python -c *)",
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git check-ignore *)",
      "PowerShell(python db.py *)",
      "PowerShell(python notify.py *)",
      "PowerShell(python -c *)",
      "PowerShell(python *.py)",
      "PowerShell(Start-Process python *)",
      "Skill(fewer-permission-prompts)",
      "Skill(fewer-permission-prompts:*)",
      "mcp__tastytrade__get_connection_status",
      "mcp__tastytrade__get_account_info",
      "mcp__tastytrade__get_market_overview",
      "mcp__tastytrade__get_option_chain",
      "mcp__tastytrade__get_strategies",
      "mcp__tastytrade__get_positions",
      "mcp__tastytrade__get_working_orders",
      "mcp__tastytrade__list_accounts",
      "mcp__tastytrade__get_watchlists"
    ]
  },
  "mcpServers": {
    "tastytrade": {
      "command": "tastytrade-mcp",
      "env": {
        "TASTYTRADE_SANDBOX": "true",
        "ENABLE_LIVE_TRADING": "false",
        "FORCE_DRY_RUN": "false",
        "BUYING_POWER_BUFFER_PCT": "25",
        "ACCOUNT_DEPLOY_LIMIT_PCT": "80"
      }
    },
    "tastytrade-mock": {
      "command": "tastytrade-mcp",
      "args": [
        "--mock",
        "--mock-fixture",
        "tests/mock_fixture.json",
        "--enable-live-trading"
      ],
      "env": {
        "BUYING_POWER_BUFFER_PCT": "25",
        "ACCOUNT_DEPLOY_LIMIT_PCT": "80"
      }
    }
  }
}
