{
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Skill(fewer-permission-prompts)",
      "Skill(fewer-permission-prompts:*)",
      "mcp__tastytrade__get_connection_status",
      "mcp__tastytrade__get_account_info",
      "mcp__tastytrade__get_market_overview",
      "mcp__tastytrade__get_option_chain",
      "mcp__tastytrade__get_strategies",
      "mcp__tastytrade__get_positions",
      "mcp__tastytrade__get_working_orders",
      "mcp__tastytrade__list_accounts",
      "mcp__tastytrade__get_watchlists",
      "mcp__tastytrade__execute_trade",
      "mcp__tastytrade__adjust_order",
      "mcp__tastytrade__close_position"
    ]
  },
  "mcpServers": {
    "tastytrade": {
      "command": "tastytrade-mcp",
      "args": [],
      "env": {
        "ENABLE_LIVE_TRADING": "false",
        "FORCE_DRY_RUN": "true",
        "BUYING_POWER_BUFFER_PCT": "25",
        "ACCOUNT_DEPLOY_LIMIT_PCT": "80"
      }
    }
  }
}